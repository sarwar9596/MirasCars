cat > .gitignore << 'EOF'
# Windows reserved names
nul
NUL
nul.*
NUL.*

# Dependencies
node_modules/
package-lock.json

# Environment files
.env
.env.local
.env.*.local

# Build outputs
dist/
build/
*.log

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.temp
EOF