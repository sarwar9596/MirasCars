cat > .gitignore << 'EOF'
# Windows reserved names
nul
NUL
nul.*
NUL.*

# Dependencies
node_modules/
package-lock.json

# Environment files (uncomment below to ignore, but user wants them tracked)
# .env
# .env.local
# .env.*.local

# Build outputs
dist/
build/
*.log

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.temp
EOF